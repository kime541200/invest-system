# API Keys
GROQ_API_KEY=<your-groq-api-key>
GEMINI_API_KEY=<your-gemini-api-key>

# Telegram 監聽設定 (給 tg_monitor.py 使用，選填)
TG_API_ID=<your-tg-api-id>
TG_API_HASH=<your-tg-api-hash>

# 交易預設設定
DEFAULT_CASH=1000000       # 回測初始資金 (台幣)
DEFAULT_COMMISSION=0.001425  # 手續費率 (台股預設 0.1425%)
DEFAULT_TAX=0.003            # 交易稅率 (台股預設 0.3%)
